{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@jarvis/contracts": ["../../packages/contracts/src/index.ts"],
      "@jarvis/shared": ["../../packages/shared/src/index.ts"],
      "@jarvis/core": ["../../packages/core/src/index.ts"],
      "@jarvis/persistence": ["../../packages/persistence/src/index.ts"]
    }
  },
  "include": ["src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx"],
  "references": [
    { "path": "../../packages/contracts" },
    { "path": "../../packages/shared" },
    { "path": "../../packages/core" }
  ]
}
