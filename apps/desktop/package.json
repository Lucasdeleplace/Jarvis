{
  "name": "@jarvis/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Application de bureau Jarvis (Electron + React + Tailwind).",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "clean": "rimraf out dist .turbo",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@jarvis/contracts": "workspace:*",
    "@jarvis/core": "workspace:*",
    "@jarvis/persistence": "workspace:*",
    "@jarvis/shared": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
