{
  "name": "@jarvis/core",
  "version": "0.0.0",
  "private": true,
  "description": "Domaine metier de Jarvis (pur, agnostique de l'infrastructure).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@jarvis/contracts": "workspace:*",
    "@jarvis/shared": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
