# ---------------------------------------------------------------------------
# Jarvis - Variables d'environnement (exemple)
# Copier ce fichier en `.env` et adapter les valeurs.
# ---------------------------------------------------------------------------

# Environnement d'execution : development | production | test
NODE_ENV=development

# --- Base de donnees (Prisma + SQLite) ---
# Chemin du fichier SQLite local.
DATABASE_URL="file:./jarvis.db"

# --- Moteur IA (Ollama) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# --- Serveur WebSocket local (temps reel entre main et renderer/outils) ---
WS_HOST=127.0.0.1
WS_PORT=8765

# --- Journalisation ---
# error | warn | info | debug
LOG_LEVEL=info
